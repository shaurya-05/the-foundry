{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Next.js)",
      "runtimeExecutable": "/Users/shauryakarra/.local/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "dev", "--port", "3000"],
      "port": 3000,
      "autoPort": false,
      "cwd": "frontend"
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "/Library/Frameworks/Python.framework/Versions/3.14/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--host", "0.0.0.0", "--port", "8000", "--loop", "asyncio"],
