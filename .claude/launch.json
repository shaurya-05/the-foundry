      "cwd": "backend"
    },
    {
      "name": "Celery Worker",
      "runtimeExecutable": "/Library/Frameworks/Python.framework/Versions/3.14/bin/celery",
      "runtimeArgs": ["-A", "workers.pipeline_worker", "worker", "--loglevel=info"],
