# ─── THE FOUNDRY — Production Environment ─────────────────────────────────────
# Copy to .env in project root for docker-compose.prod.yml
# Generate secrets: openssl rand -hex 32

# ─── Secrets (REQUIRED — generate unique values) ─────────────────────────────
JWT_SECRET=
POSTGRES_PASSWORD=
REDIS_PASSWORD=
NEO4J_PASSWORD=

# ─── AI Keys (REQUIRED) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# ─── Email (REQUIRED for user flows) ─────────────────────────────────────────
RESEND_API_KEY=

# ─── URLs (REQUIRED — set to your domain) ────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# ─── Monitoring (Recommended) ────────────────────────────────────────────────
SENTRY_DSN=
