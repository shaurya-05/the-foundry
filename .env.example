# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
VOYAGE_API_KEY=pa-...

# ─── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# Local (Docker):  postgresql://foundry:foundry_secret@localhost:5432/foundry_db
# Railway: copy the "Postgres connection URL" from the Railway dashboard
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local:    redis://localhost:6379
# Railway: copy the Redis "connection URL" from the Railway dashboard
REDIS_URL=redis://default:password@host:6379

# ─── Neo4j (optional — app starts fine without it) ────────────────────────────
# Local:   bolt://localhost:7687
# AuraDB:  neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=foundry_secret

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_in_production_use_long_random_string

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Production: ALLOWED_ORIGINS=https://thefoundry.vercel.app,https://yourdomain.com
# Dev default (used if unset): http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Supabase (optional auth provider) ────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── App ──────────────────────────────────────────────────────────────────────
# Set to "production" on Railway to disable debug output
ENVIRONMENT=development

# ─── Frontend (set in Vercel dashboard or frontend/.env.local) ────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Production:
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app
# NEXT_PUBLIC_WS_URL=wss://your-backend.railway.app
