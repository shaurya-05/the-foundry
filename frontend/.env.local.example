# ─── Local development ──────────────────────────────────────────────────────
# Point at a local backend (Docker Compose: see backend/.env.example)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── Production (set in Vercel, not committed) ──────────────────────────────
# Phase 2 §3.1: production targets the api.found3ry.com custom domain.
# NEVER set these to *.up.railway.app — next.config.mjs will refuse to build.
# NEXT_PUBLIC_API_URL=https://api.found3ry.com
# NEXT_PUBLIC_WS_URL=wss://api.found3ry.com
