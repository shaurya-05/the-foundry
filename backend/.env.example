# ─── THE FOUNDRY — Backend Environment ───────────────────────────────────────
# Copy to .env and fill in your actual values. NEVER commit .env to git.

# ─── Core ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                          # development | production
# IMPORTANT: Generate a strong secret for production: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx
VOYAGE_API_KEY=pa-xxxx

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://foundry:foundry_secret@localhost:5432/foundry_db
REDIS_URL=redis://localhost:6379
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=foundry_secret

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Optional — falls back to console logging if not set
RESEND_API_KEY=
EMAIL_FROM=The FOUND3RY <noreply@yourdomain.com>

# ─── Frontend / CORS ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Monitoring (optional) ───────────────────────────────────────────────────
SENTRY_DSN=

# ─── Legacy (optional) ───────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
